#!/usr/bin/env bash
# Collect non-secret diagnostics after an SDDM/Hyprland login loop.
set -u
export PATH="$HOME/.local/bin:$PATH"

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/hyprsequoia"
log_dir="$state_dir/logs"
mkdir -p "$log_dir"
report="$log_dir/diagnose-$(date +%Y%m%d-%H%M%S).log"
exec > >(tee "$report") 2>&1

printf 'HyprSequoia diagnostic report\nGenerated: %s\n\n' "$(date --iso-8601=seconds 2>/dev/null || date)"
printf '%s\n' '== Versions =='
uname -a 2>/dev/null || true
if command -v Hyprland >/dev/null 2>&1; then Hyprland --version 2>&1 || true
elif command -v hyprland >/dev/null 2>&1; then hyprland --version 2>&1 || true
else printf '%s\n' 'Hyprland: not found'; fi
if command -v pacman >/dev/null 2>&1; then
    pacman -Q hyprland aquamarine hyprutils hyprlang hyprgraphics hyprland-guiutils 2>/dev/null || true
fi
if command -v start-hyprland >/dev/null 2>&1; then
    printf 'start-hyprland: %s\n' "$(command -v start-hyprland)"
fi

printf '\n%s\n' '== GPU and kernel driver =='
if command -v lspci >/dev/null 2>&1; then
    lspci -nnk 2>/dev/null | sed -n '/VGA compatible controller\|3D controller\|Display controller/,+3p' || true
else printf '%s\n' 'lspci: not installed'; fi
if [[ -r /sys/module/nvidia_drm/parameters/modeset ]]; then
    printf 'nvidia_drm.modeset=%s\n' "$(< /sys/module/nvidia_drm/parameters/modeset)"
fi

printf '\n%s\n' '== Config verification =='
config="$HOME/.config/hypr/hyprland.conf"
if [[ -r $config ]] && command -v Hyprland >/dev/null 2>&1; then
    Hyprland --config "$config" --verify-config 2>&1 || true
else printf '%s\n' "Cannot verify $config from this host."; fi

printf '\n%s\n' '== SDDM and user journal (tail) =='
if command -v journalctl >/dev/null 2>&1; then
    journalctl -b -u sddm --no-pager -n 120 2>&1 || true
    journalctl --user -b --no-pager -n 160 2>&1 || true
fi
if command -v coredumpctl >/dev/null 2>&1; then
    printf '\n%s\n' '== Recent Hyprland coredumps =='
    coredumpctl list --no-pager --reverse Hyprland 2>&1 | head -n 10 || true
fi

printf '\n%s\n' '== Hyprland crash reports =='
find "$HOME/.cache/hyprland" -maxdepth 1 -type f -name 'hyprlandCrashReport*' -print \
    -exec tail -n 100 {} \; 2>/dev/null || true

printf '\n%s\n' '== Latest Hyprland runtime log =='
runtime_hypr="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/hypr"
latest_log=$(find "$runtime_hypr" -type f -name hyprland.log -printf '%T@ %p\n' 2>/dev/null \
    | sort -nr | head -n 1 | cut -d' ' -f2-)
if [[ -n $latest_log && -r $latest_log ]]; then
    printf 'Log: %s\n' "$latest_log"
    tail -n 180 "$latest_log" || true
else
    printf '%s\n' 'No Hyprland runtime log found.'
fi

printf '\nReport saved to: %s\n' "$report"
