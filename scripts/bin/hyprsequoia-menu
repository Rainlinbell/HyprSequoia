#!/usr/bin/env bash
# Apple-menu-inspired session command palette.
set -Eeuo pipefail
choice=$(printf 'About HyprSequoia\nSystem Settings\nLock Screen\nLog Out\nRestart\nShut Down' | walker --dmenu 2>/dev/null || true)
case $choice in
  'About HyprSequoia') hyprsequoia-settings about ;;
  'System Settings')
    if command -v hyprsequoia-settings >/dev/null 2>&1; then
      hyprsequoia-settings
    elif command -v systemsettings >/dev/null 2>&1; then
      systemsettings
    else
      notify-send 'HyprSequoia' 'Use the menu-bar controls for network, Bluetooth, and sound.'
    fi
    ;;
  'Lock Screen') loginctl lock-session ;;
  'Log Out') hyprctl dispatch exit ;;
  'Restart') systemctl reboot ;;
  'Shut Down') systemctl poweroff ;;
esac
