#!/usr/bin/env bash
# Start hyprpaper with a current-format config and a safe SVG fallback.
set -u
export PATH="$HOME/.local/bin:$PATH"

state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/hyprsequoia"
log_dir="$state_dir/logs"
cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/hyprsequoia"
mkdir -p "$log_dir" "$cache_dir"
log="$log_dir/wallpaper-$(date +%Y%m%d-%H%M%S).log"
source_image="$HOME/.config/hypr/wallpapers/default.svg"
image="$source_image"

if [[ ! -r $source_image ]]; then
    printf '[HyprSequoia] wallpaper asset missing: %s\n' "$source_image" >>"$log"
    exit 0
fi

# Hyprpaper does not decode SVG. Prefer librsvg's deterministic converter, then
# fall back to ImageMagick when its optional SVG delegate is available.
if [[ $source_image == *.svg ]]; then
    image="$cache_dir/default.png"
    if [[ ! -s $image || $source_image -nt $image ]]; then
        tmp=$(mktemp "$cache_dir/default.XXXXXX.png")
        rendered=0
        if command -v rsvg-convert >/dev/null 2>&1; then
            if rsvg-convert --width 2560 --height 1440 --output "$tmp" "$source_image" >>"$log" 2>&1; then
                rendered=1
            fi
        elif command -v magick >/dev/null 2>&1; then
            if magick -background none "$source_image" -resize 2560x1440 "$tmp" >>"$log" 2>&1; then
                rendered=1
            fi
        elif command -v convert >/dev/null 2>&1; then
            if convert -background none "$source_image" -resize 2560x1440 "$tmp" >>"$log" 2>&1; then
                rendered=1
            fi
        fi
        if ((rendered == 0)) || [[ ! -s $tmp ]]; then
            printf '[HyprSequoia] could not rasterize SVG; skipping wallpaper\n' >>"$log"
            rm -f -- "$tmp" "$image"
            exit 0
        fi
        mv -- "$tmp" "$image"
    fi
fi

config="$cache_dir/hyprpaper.conf"
{
    printf 'splash = false\n'
    printf 'wallpaper {\n  monitor =\n  path = %s\n  fit_mode = cover\n}\n' "$image"
} >"$config"

if command -v hyprpaper >/dev/null 2>&1; then
    printf '[HyprSequoia] starting hyprpaper with %s\n' "$image" >>"$log"
    exec hyprpaper --config "$config" >>"$log" 2>&1
fi
printf '[HyprSequoia] hyprpaper is not installed; leaving compositor background untouched\n' >>"$log"
